<!-- 提前还款计算 -->
<view class="page">
  <!-- 基本参数 -->
  <view class="card">
    <view class="input-group">
      <view class="input-label">贷款总额<text class="unit">（万元）</text></view>
      <view class="input-wrapper {{loanAmountFocus ? 'focus' : ''}}">
        <input type="digit" value="{{loanAmount}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur"
               data-field="loanAmount" placeholder="请输入贷款总额" />
        <text class="input-suffix">万元</text>
      </view>
    </view>

    <view class="input-group">
      <view class="input-label">年利率<text class="unit">（%）</text></view>
      <view class="input-wrapper {{loanRateFocus ? 'focus' : ''}}">
        <input type="digit" value="{{loanRate}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur"
               data-field="loanRate" placeholder="请输入年利率" />
        <text class="input-suffix">%</text>
      </view>
    </view>

    <!-- 贷款年限 -->
    <view class="input-group">
      <view class="input-label">贷款年限</view>
      <view class="segment" style="margin-bottom:0;padding:2rpx;">
        <view class="segment-item {{loanYear == 10 ? 'active' : ''}}" bindtap="setLoanYear" data-year="{{10}}">10年</view>
        <view class="segment-item {{loanYear == 20 ? 'active' : ''}}" bindtap="setLoanYear" data-year="{{20}}">20年</view>
        <view class="segment-item {{loanYear == 30 ? 'active' : ''}}" bindtap="setLoanYear" data-year="{{30}}">30年</view>
      </view>
    </view>

    <!-- 还款方式 -->
    <view class="segment">
      <view class="segment-item {{repayType === 'equal-payment' ? 'active' : ''}}"
            bindtap="setRepayType" data-type="equal-payment">等额本息</view>
      <view class="segment-item {{repayType === 'equal-principal' ? 'active' : ''}}"
            bindtap="setRepayType" data-type="equal-principal">等额本金</view>
    </view>

    <!-- 已还期数 -->
    <view class="input-group">
      <view class="input-label">已还期数<text class="unit">（月）</text></view>
      <view class="input-wrapper {{paidMonthsFocus ? 'focus' : ''}}">
        <input type="number" value="{{paidMonths}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur"
               data-field="paidMonths" placeholder="已还款月数" />
        <text class="input-suffix">个月</text>
      </view>
    </view>

    <!-- 提前还款金额 -->
    <view class="input-group">
      <view class="input-label">提前还款金额<text class="unit">（万元）</text></view>
      <view class="input-wrapper {{prepayAmountFocus ? 'focus' : ''}}">
        <input type="digit" value="{{prepayAmount}}" bindinput="onInput" bindfocus="onFocus" bindblur="onBlur"
               data-field="prepayAmount" placeholder="提前还款金额" />
        <text class="input-suffix">万元</text>
      </view>
    </view>

    <!-- 还款方案 -->
    <view class="input-group">
      <view class="input-label">还款后方案</view>
      <view class="segment" style="margin-bottom:0;padding:2rpx;">
        <view class="segment-item {{prepayType === 'reduce-month' ? 'active' : ''}}"
              bindtap="setPrepayType" data-type="reduce-month">缩短年限</view>
        <view class="segment-item {{prepayType === 'reduce-payment' ? 'active' : ''}}"
              bindtap="setPrepayType" data-type="reduce-payment">减少月供</view>
      </view>
    </view>

    <view class="btn-primary" bindtap="calculate">计算提前还款</view>
  </view>

  <!-- 结果展示 -->
  <view class="card" wx:if="{{result}}">
    <view style="font-size:24rpx;color:#999;text-align:center;">提前还款 ¥{{prepayAmountDisplay}}万 后</view>
    
    <view class="data-grid">
      <view class="data-item">
        <view class="value">¥{{result.paidInterestDisplay}}万</view>
        <view class="label">已付利息</view>
      </view>
      <view class="data-item">
        <view class="value">¥{{result.remainingBeforeDisplay}}万</view>
        <view class="label">剩余本金（还前）</view>
      </view>
      <view class="data-item">
        <view class="value">¥{{result.remainingAfterDisplay}}万</view>
        <view class="label">剩余本金（还后）</view>
      </view>
      <view class="data-item">
        <view class="value" style="color:#2ed573;">¥{{result.interestSavedDisplay}}万</view>
        <view class="label">节省利息</view>
      </view>
    </view>

    <!-- 月供对比 -->
    <view wx:if="{{result.originalMonthlyPayment > 0}}" style="margin-top:24rpx;padding:20rpx;background:#f8f9fb;border-radius:12rpx;">
      <view style="display:flex;justify-content:space-between;margin-bottom:12rpx;">
        <text style="color:#999;">原月供</text>
        <text style="font-weight:600;">¥{{result.originalMonthlyDisplay}}</text>
      </view>
      <view style="display:flex;justify-content:space-between;">
        <text style="color:#999;">新月供</text>
        <text style="font-weight:600;color:#1a73e8;">¥{{result.newMonthlyDisplay}}</text>
      </view>
      <view wx:if="{{result.newResult.newMonths}}" style="display:flex;justify-content:space-between;margin-top:12rpx;padding-top:12rpx;border-top:1rpx solid #e0e0e0;">
        <text style="color:#999;">剩余还款期数</text>
        <text style="font-weight:600;">{{result.newResult.newMonths}} 个月（约{{result.newYears}}年）</text>
      </view>
    </view>

    <!-- 方案说明 -->
    <view style="margin-top:16rpx;padding:16rpx;background:#fff8e1;border-radius:8rpx;font-size:24rpx;color:#b8860b;">
      {{result.newResult.description}}
    </view>
  </view>
</view>
