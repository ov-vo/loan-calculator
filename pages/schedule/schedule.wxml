<!-- 还款计划表 -->
<view class="page">
  <!-- 参数摘要 -->
  <view class="card" style="padding:24rpx;">
    <view style="display:flex;justify-content:space-between;font-size:24rpx;color:#999;margin-bottom:8rpx;">
      <text>贷款{{loanAmount}}万 · {{loanYear}}年 · {{loanRate}}%</text>
      <text>{{repayTypeName}}</text>
    </view>
    <view style="display:flex;justify-content:space-between;">
      <text style="font-size:28rpx;font-weight:600;">月供 ¥{{monthlyDisplay}}</text>
      <text style="color:#ff6b6b;font-size:24rpx;">总利息 ¥{{totalInterestDisplay}}万</text>
    </view>
  </view>

  <!-- 图表：本金/利息占比走势 -->
  <view class="card" wx:if="{{scheduleData.length > 0}}">
    <view style="font-size:28rpx;font-weight:600;margin-bottom:16rpx;">本金与利息构成变化</view>
    
    <!-- 堆叠条形图 -->
    <view class="stacked-chart">
      <block wx:for="{{chartPoints}}" wx:key="index">
        <view class="chart-row">
          <text class="chart-label">{{item.label}}</text>
          <view class="chart-bar">
            <view class="chart-bar-interest" style="width:{{item.interestPct}}%;"></view>
            <view class="chart-bar-principal" style="width:{{item.principalPct}}%;"></view>
          </view>
          <text class="chart-val">¥{{item.totalDisplay}}</text>
        </view>
      </block>
    </view>
    <view style="display:flex;justify-content:center;gap:40rpx;margin-top:12rpx;font-size:22rpx;color:#999;">
      <view style="display:flex;align-items:center;">
        <view style="width:16rpx;height:16rpx;background:#ff6b6b;border-radius:4rpx;margin-right:6rpx;"></view>
        <text>利息</text>
      </view>
      <view style="display:flex;align-items:center;">
        <view style="width:16rpx;height:16rpx;background:#4ecb71;border-radius:4rpx;margin-right:6rpx;"></view>
        <text>本金</text>
      </view>
    </view>
  </view>

  <!-- 还款明细列表 -->
  <view class="card" style="padding:0;overflow:hidden;">
    <view style="display:flex;justify-content:space-between;align-items:center;padding:24rpx 30rpx;border-bottom:1rpx solid #f0f0f0;">
      <text style="font-size:28rpx;font-weight:600;">还款明细</text>
      <text style="font-size:22rpx;color:#999;">共{{totalMonths}}期</text>
    </view>

    <!-- 年份筛选 -->
    <scroll-view scroll-x class="year-filter">
      <block wx:for="{{years}}" wx:key="*this">
        <view class="year-tag {{selectedYear === item ? 'active' : ''}}" 
              bindtap="selectYear" data-year="{{item}}">第{{item}}年</view>
      </block>
    </scroll-view>

    <!-- 表头 -->
    <view class="table-header">
      <text class="col-period">期数</text>
      <text class="col-payment">月供</text>
      <text class="col-principal">本金</text>
      <text class="col-interest">利息</text>
      <text class="col-remain">剩余</text>
    </view>

    <!-- 数据行 -->
    <scroll-view scroll-y style="max-height:800rpx;">
      <block wx:for="{{displaySchedule}}" wx:key="period">
        <view class="table-row {{index % 2 === 0 ? 'even' : ''}}">
          <text class="col-period">{{item.period}}</text>
          <text class="col-payment">{{item.monthlyDisplay}}</text>
          <text class="col-principal">{{item.principalDisplay}}</text>
          <text class="col-interest">{{item.interestDisplay}}</text>
          <text class="col-remain">{{item.remainDisplay}}</text>
        </view>
      </block>
    </scroll-view>

    <view wx:if="{{displaySchedule.length === 0}}" style="padding:60rpx;text-align:center;color:#999;">
      <text>请先到计算页面完成贷款计算</text>
    </view>
  </view>

  <!-- 年度汇总 -->
  <view class="card" wx:if="{{displaySchedule.length > 0}}">
    <view style="font-size:28rpx;font-weight:600;margin-bottom:16rpx;">第{{selectedYear}}年还款汇总</view>
    <view class="data-grid">
      <view class="data-item">
        <view class="value">¥{{yearSummary.totalPayment}}</view>
        <view class="label">年度总还款</view>
      </view>
      <view class="data-item">
        <view class="value">¥{{yearSummary.totalPrincipal}}</view>
        <view class="label">已还本金</view>
      </view>
      <view class="data-item">
        <view class="value">¥{{yearSummary.totalInterest}}</view>
        <view class="label">已付利息</view>
      </view>
      <view class="data-item">
        <view class="value">¥{{yearSummary.remaining}}</view>
        <view class="label">剩余本金</view>
      </view>
    </view>
  </view>
</view>
