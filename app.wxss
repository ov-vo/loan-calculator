/* 全局样式 */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Microsoft YaHei', sans-serif;
  font-size: 28rpx;
  color: #333;
  background-color: #f5f6f8;
  line-height: 1.6;
}

/* 通用卡片 */
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 通用输入组 */
.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.input-label .unit {
  font-size: 24rpx;
  color: #999;
  margin-left: 8rpx;
  font-weight: normal;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  height: 80rpx;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.input-wrapper.focus {
  border-color: #1a73e8;
  background: #fff;
}

.input-wrapper input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #333;
}

.input-suffix {
  font-size: 26rpx;
  color: #666;
  margin-left: 8rpx;
  flex-shrink: 0;
}

/* 通用按钮 */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #1a73e8, #1557b0);
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 44rpx;
  margin: 30rpx 20rpx;
  letter-spacing: 2rpx;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

.btn-secondary {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  background: #f0f4ff;
  color: #1a73e8;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 40rpx;
  border: 2rpx solid #d0ddff;
}

.btn-secondary:active {
  background: #e0e8ff;
}

/* 分段选择器 */
.segment {
  display: flex;
  background: #f0f1f3;
  border-radius: 12rpx;
  padding: 4rpx;
  margin-bottom: 24rpx;
}

.segment-item {
  flex: 1;
  text-align: center;
  padding: 14rpx 0;
  font-size: 26rpx;
  color: #666;
  border-radius: 10rpx;
  transition: all 0.2s;
}

.segment-item.active {
  background: #fff;
  color: #1a73e8;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

/* 结果展示 */
.result-highlight {
  font-size: 60rpx;
  font-weight: 700;
  color: #1a73e8;
  text-align: center;
  margin: 10rpx 0;
}

.result-label {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 数据网格 */
.data-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 24rpx;
}

.data-item {
  background: #f7f8fa;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.data-item .value {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
}

.data-item .label {
  font-size: 22rpx;
  color: #999;
  margin-top: 6rpx;
}

/* 图表/对比区域 */
.compare-bar {
  display: flex;
  align-items: flex-end;
  justify-content: center;
  gap: 40rpx;
  padding: 30rpx 0;
}

.compare-col {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.compare-col .bar {
  border-radius: 8rpx 8rpx 0 0;
  width: 60rpx;
  transition: height 0.5s ease;
}

.compare-col .bar.interest {
  background: linear-gradient(to top, #ff6b6b, #ff8e8e);
}

.compare-col .bar.principal {
  background: linear-gradient(to top, #4ecb71, #6fe08a);
}

.compare-col .bar-text {
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 8rpx;
}

/* 颜色 */
.color-primary { color: #1a73e8; }
.color-danger { color: #ff4757; }
.color-success { color: #2ed573; }
.color-warning { color: #ffa502; }
.color-muted { color: #999; }
